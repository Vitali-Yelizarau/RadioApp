<Window x:Class="RadioApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:RadioApp"
        mc:Ignorable="d"
        Title="My Radio Player" Height="350" Width="700" MinWidth="500" MinHeight="300" MaxWidth="700" MaxHeight="350">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="235"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid >
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.RowSpan="2"
                            VerticalAlignment="Bottom"
                            HorizontalAlignment="Center"
                            Margin="0,0,0,18">

                    <Grid Margin="0,0,0,14"
                          Width="150">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Content="⏮"
                                x:Name="PreviousItemButton"
                                Grid.Column="0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="PreviousItemButton_Click"/>

                        <Button Content="▶"
                                x:Name="PlayPauseButton"
                                Grid.Column="1"
                                Click="PlayPauseButton_Click"
                                Margin="2,0,2,0"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"/>

                        <Button Content="⏭"
                                x:Name="NextItemButton"
                                Grid.Column="2"
                                HorizontalContentAlignment="Center"
                                VerticalContentAlignment="Center"
                                Click="NextItemButton_Click"/>
                    </Grid>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center">

                            <TextBlock Text="&#xE995;"
                                       FontFamily="Segoe MDL2 Assets"
                                       FontSize="16"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"/>

                            <Slider x:Name="VolumeSlider"
                                    Width="105"
                                    Minimum="0"
                                    Maximum="100"
                                    Value="80"
                                    VerticalAlignment="Center"
                                    ValueChanged="VolumeSlider_ValueChanged"/>

                        <TextBlock x:Name="VolumeValueTextBlock"
                                   Text="80%"
                                   Width="34"
                                   Margin="8,0,0,0"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <TextBlock x:Name="NowPlayingTextBlock"
                           TextWrapping="Wrap"  
                           TextAlignment="Center" 
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Text="Now playing: "/>
            </Grid>
        </Grid>
        <Grid Grid.Column="1" x:Name="StationsListAndButtonsGrid">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="30"/>
            </Grid.RowDefinitions>
            <ListBox x:Name="StationsListBox"
                     Grid.Row="0"
                     Grid.Column="1"
                     AllowDrop="True"
                     PreviewMouseLeftButtonDown="StationsListBox_PreviewMouseLeftButtonDown"
                     MouseMove="StationsListBox_MouseMove"
                     Drop="StationsListBox_Drop"
                     MouseDoubleClick="StationsListBox_MouseDoubleClick">

                <ListBox.ContextMenu>
                    <ContextMenu>
                        <MenuItem Header="Sort by...">

                            <MenuItem Header="Name">
                                <MenuItem Header="Ascending"
                              Click="SortStationsByNameAscendingMenuItem_Click"/>

                                <MenuItem Header="Descending"
                              Click="SortStationsByNameDescendingMenuItem_Click"/>
                            </MenuItem>

                            <MenuItem Header="Play count">
                                <MenuItem Header="Ascending"
                              Click="SortStationsByPlayCountAscendingMenuItem_Click"/>

                                <MenuItem Header="Descending"
                              Click="SortStationsByPlayCountDescendingMenuItem_Click"/>
                            </MenuItem>

                        </MenuItem>
                    </ContextMenu>
                </ListBox.ContextMenu>

                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Title}"
                                   TextTrimming="CharacterEllipsis">
                                <TextBlock.ToolTip>
                                    <ToolTip>
                                        <TextBlock Text="{Binding Description}"
                                       TextWrapping="Wrap"
                                       MaxWidth="300"/>
                                    </ToolTip>
                                </TextBlock.ToolTip>
                            </TextBlock>
                    </DataTemplate>
                </ListBox.ItemTemplate>

            </ListBox>
            
            <Grid Grid.Row="1" x:Name="PlaylistButtonGrid">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Button x:Name="AddButton" FontFamily="Segoe MDL2 Assets"
                        Content="&#xE710;"
                        FontSize="22"
                        ToolTip="Add station"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center" Click="AddButton_Click"/>

                <Button Grid.Column="1" x:Name="DeleteButton"
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE738;"
                        FontSize="22"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip="Delete station" Click="DeleteButton_ClickAsync"/>
                
                <Button x:Name="EditButton"
                        Grid.Column="2" 
                        FontFamily="Segoe MDL2 Assets"
                        Content="&#xE70F;"
                        FontSize="20"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        ToolTip="Edit station" Click="EditButton_Click"/>
            </Grid>
                
            </Grid>
        </Grid>
</Window>
